INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Comma-separated hashtags to monitor (no # symbol)
HASHTAGS=fitness,motivation,travel

# How often to run the cycle (in hours)
POST_INTERVAL_HOURS=6

# Max posts per run cycle (keeps you under Instagram limits)
MAX_POSTS_PER_CYCLE=2

# Seconds to wait between posting reels
DELAY_BETWEEN_POSTS=60
